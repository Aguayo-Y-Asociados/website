<style>
  .featured-articles {
    padding: 80px 0;
    background-color: #f8fafc;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .title-articles {
    text-align: center;
    margin-bottom: 40px;
  }

  .title-articles h2 {
    font-size: 32px;
    color: #1e293b;
    font-weight: 700;
  }

  .carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .cards-articles {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 20px 0;
    scrollbar-width: none;
  }

  .cards-articles::-webkit-scrollbar {
    display: none;
  }

  .card-link {
    text-decoration: none;
    flex: 0 0 calc(33.333% - 16px);
    scroll-snap-align: start;
  }

  .card-article {
    background: white;
    border-radius: 4px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .image-article img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  .entry-text {
    padding: 24px;
  }

  .title-article h3 {
    font-size: 19px;
    color: #1e293b;
    margin-bottom: 12px;
    line-height: 1.4;
  }

  .content-article p {
    font-size: 15px;
    color: #64748b;
    line-height: 1.6;
  }

  /* Flechas Corregidas */
  .prev-btn,
  .next-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.8;
    background: #000;
    color: white;
    border: none;
    width: 35px;
    height: 50px;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .prev-btn:hover,
  .next-btn:hover {
    opacity: 1;
  }

  .prev-btn {
    left: 12px;
    border-radius: 4px;
  }
  .next-btn {
    right: 12px;
    border-radius: 4px;
  }

  .prev-btn svg,
  .next-btn svg {
    width: 20px;
    height: 20px;
  }

  /* Puntos Corregidos */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  @media (max-width: 900px) {
    .card-link {
      flex: 0 0 calc(50% - 12px);
    }
  }

  @media (max-width: 600px) {
    .card-link {
      flex: 0 0 100%;
    }
    .prev-btn,
    .next-btn {
      display: none;
    }
  }
</style>

<script>
  const carousel = document.getElementById("carousel");
  const dotsContainer = document.getElementById("dots");
  const prevBtn = document.querySelector(".prev-btn");
  const nextBtn = document.querySelector(".next-btn");
  const cards = document.querySelectorAll(".card-link");

  // Crear puntos
  cards.forEach((_, i) => {
    const dot = document.createElement("button");
    dot.classList.add("dot");
    if (i === 0) dot.classList.add("active");
    dot.addEventListener("click", () => {
      carousel.scrollTo({
        left: cards[i].offsetLeft - carousel.offsetLeft,
        behavior: "smooth",
      });
    });
    dotsContainer.appendChild(dot);
  });

  // Sincronizar puntos con scroll
  carousel.addEventListener("scroll", () => {
    const cardWidth = cards[0].offsetWidth + 24;
    const index = Math.round(carousel.scrollLeft / cardWidth);
    document.querySelectorAll(".dot").forEach((dot, i) => {
      dot.classList.toggle("active", i === index);
    });
  });

  // Lógica Infinita
  nextBtn.addEventListener("click", () => {
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    if (carousel.scrollLeft >= maxScroll - 10) {
      carousel.scrollTo({ left: 0, behavior: "smooth" });
    } else {
      carousel.scrollBy({
        left: cards[0].offsetWidth + 24,
        behavior: "smooth",
      });
    }
  });

  prevBtn.addEventListener("click", () => {
    if (carousel.scrollLeft <= 10) {
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      carousel.scrollTo({ left: maxScroll, behavior: "smooth" });
    } else {
      carousel.scrollBy({
        left: -(cards[0].offsetWidth + 24),
        behavior: "smooth",
      });
    }
  });
</script>
