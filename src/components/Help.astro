<section class="help-section">
  <!-- contenido superior de la seccion -->
  <div class="container">
    <div class="top-help-content">
      <h3>We’ll help you get started</h3>

      <p>
        With access to detailed documentation, regular training sessions, and a
        responsive support team, you can be confident that you’re fully
        supported as you build, customize, and maintain a professional-quality
        website.
      </p>
    </div>

    <!-- contenido inferior de la seccion -->
    <div class="bottom-help-content">
      <!-- primera card -->
      <div class="bottom-help-card">
        <div class="image-card">
          <img
            src="https://www.kadencewp.com/wp-content/uploads/2024/07/Kadence-Support-1024x683.jpg"
            alt="Kadence offers friendly personal support"
          />
        </div>

        <div class="content-card">
          <h4>Fast, helpful support</h4>

          <p>
            Your success is our success. Our support team goes above and beyond
            to help, earning praise from customers as the “best they’ve ever
            received.”
          </p>
        </div>

        <div class="button-card">
          <a href="#">
            <span> Submit a ticket </span>

            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              color="#000"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <!-- segunda card -->
      <div class="bottom-help-card">
        <div class="image-card">
          <img
            src="https://www.kadencewp.com/wp-content/uploads/2024/07/Kadence-Tutorials-Documentation.jpg"
            alt="Kadence offers friendly personal support"
          />
        </div>

        <div class="content-card">
          <h4>Tutorials & Documentation</h4>

          <p>
            Access answers anytime about setup, settings, and advanced use cases
            to make the most of Kadence products.
          </p>
        </div>

        <div class="button-card">
          <a href="#">
            <span> Help center </span>

            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              color="#000"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <!-- tercera card -->
      <div class="bottom-help-card">
        <div class="image-card">
          <img
            src="https://www.kadencewp.com/wp-content/uploads/2024/07/Kadence-Community.jpg"
            alt="Kadence offers friendly personal support"
          />
        </div>

        <div class="content-card">
          <h4>Community – 15k Active Members</h4>

          <p>
            Join a thriving group of Kadence users, from beginners to pros. Get
            quick solutions, share tips, and learn from others in our supportive
            community.
          </p>
        </div>

        <div class="button-card">
          <a href="#">
            <span> Join our active community </span>

            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              color="#000"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>

      <!-- cuarta card -->
      <div class="bottom-help-card">
        <div class="image-card">
          <img
            src="https://www.kadencewp.com/wp-content/uploads/2024/07/Kadence-Marketplace.jpg"
            alt="Kadence offers friendly personal support"
          />
        </div>

        <div class="content-card">
          <h4>Marketplace</h4>

          <p>
            Discover resources to power your project, including niche themes,
            starter templates, prebuilt design libraries, and Kadence experts
            for hire.
          </p>
        </div>

        <div class="button-card">
          <a href="#">
            <span> Browse </span>

            <svg
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              stroke="currentColor"
              color="#000"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .help-section {
    /* padding: 80px 0; */
    /* background-color: #fcfcfd; */
    font-family: sans-serif;
  }

  /* Contenido Superior */
  .top-help-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px auto;
  }

  .top-help-content h3 {
    font-size: 42px;
    color: #1e293b;
    margin-bottom: 20px;
    font-weight: 700;
  }

  .top-help-content p {
    font-size: 18px;
    color: #64748b;
    line-height: 1.6;
  }

  /* Grid de Cards */
  .bottom-help-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
  }

  .bottom-help-card {
    background: #ffffff;
    border-radius: 4px;
    border: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease;
  }

  .bottom-help-card:hover {
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
  }

  /* Imagen de la Card */
  .image-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  /* Contenido de la Card */
  .content-card {
    padding: 24px;
    flex-grow: 1;
  }

  .content-card h4 {
    font-size: 20px;
    color: #1e293b;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .content-card p {
    font-size: 15px;
    color: #64748b;
    line-height: 1.5;
    margin: 0;
  }

  /* Botón/Link de la Card */
  .button-card {
    padding: 0 24px 24px 24px;
  }

  .button-card a {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: #1e293b;
    font-weight: 600;
    font-size: 15px;
    transition: color 0.2s;
  }

  .button-card a:hover {
    color: #4f46e5;
  }

  .button-card svg {
    transition: transform 0.2s ease;
  }

  .button-card a:hover svg {
    transform: translateX(4px);
    color: inherit;
  }

  @media (max-width: 768px) {
    .top-help-content h3 {
      font-size: 32px;
    }
  }
</style>
