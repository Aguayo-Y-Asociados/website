<style>
  .whatsapp-wrapper {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  /* ===== TOOLTIP / CHAT BUBBLE ===== */
  .whatsapp-tooltip {
    background: #ffffff;
    border-radius: 16px;
    padding: 22px 24px;
    width: 280px;
    box-shadow:
      0 8px 30px rgba(0, 0, 0, 0.12),
      0 2px 8px rgba(0, 0, 0, 0.06);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px) scale(0.95);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0.3s ease;
    position: relative;
  }

  .whatsapp-tooltip.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .whatsapp-tooltip::after {
    content: "";
    position: absolute;
    bottom: -8px;
    right: 28px;
    width: 16px;
    height: 16px;
    background: #ffffff;
    transform: rotate(45deg);
    box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.04);
  }

  .tooltip-close {
    position: absolute;
    top: 8px;
    right: 12px;
    background: none;
    border: none;
    font-size: 20px;
    color: #9ca3af;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.2s ease;
  }

  .tooltip-close:hover {
    color: #374151;
  }

  .tooltip-greeting {
    font-size: 14px;
    color: #6b7280;
    margin: 0 0 2px 0;
  }

  .tooltip-brand {
    font-size: 17px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 10px 0;
  }

  .tooltip-text {
    font-size: 13.5px;
    color: #4b5563;
    line-height: 1.5;
    margin: 0 0 16px 0;
  }

  .tooltip-btn {
    display: block;
    background: #25d366;
    color: #ffffff;
    text-align: center;
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .tooltip-btn:hover {
    background: #1ebe5d;
    transform: translateY(-1px);
  }

  /* ===== GREEN BUTTON ===== */
  .whatsapp-button {
    width: 60px;
    height: 60px;
    background: #25d366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 4px 14px rgba(37, 211, 102, 0.4),
      0 2px 6px rgba(0, 0, 0, 0.1);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    position: relative;
    text-decoration: none;
  }

  .whatsapp-button:hover {
    transform: scale(1.1);
    box-shadow:
      0 6px 20px rgba(37, 211, 102, 0.5),
      0 3px 10px rgba(0, 0, 0, 0.12);
  }

  .whatsapp-button svg {
    width: 32px;
    height: 32px;
    fill: #ffffff;
  }

  /* ===== PING ANIMATION ===== */
  .whatsapp-ping {
    position: absolute;
    top: -2px;
    right: -2px;
    width: 16px;
    height: 16px;
    background: #ef4444;
    border-radius: 50%;
    border: 2px solid #ffffff;
  }

  .whatsapp-ping::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #ef4444;
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    75%,
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  /* ===== ENTRANCE ANIMATION ===== */
  .whatsapp-button {
    animation: bounceIn 0.6s ease 1s both;
  }

  @keyframes bounceIn {
    0% {
      transform: scale(0);
      opacity: 0;
    }
    60% {
      transform: scale(1.15);
      opacity: 1;
    }
    100% {
      transform: scale(1);
    }
  }

  @media (max-width: 480px) {
    .whatsapp-wrapper {
      bottom: 18px;
      right: 18px;
    }

    .whatsapp-tooltip {
      width: 250px;
    }

    .whatsapp-button {
      width: 54px;
      height: 54px;
    }

    .whatsapp-button svg {
      width: 28px;
      height: 28px;
    }
  }
</style>

<script>
  const wrapper = document.getElementById("whatsapp-wrapper");
  const button = document.getElementById("whatsapp-button");
  const tooltip = document.getElementById("whatsapp-tooltip");
  const closeBtn = document.getElementById("tooltip-close");

  if (wrapper && button && tooltip && closeBtn) {
    let dismissed = false;
    let hoverOpen = false;

    // Auto-show tooltip after 3 seconds
    setTimeout(() => {
      if (!dismissed) {
        tooltip.classList.add("visible");
      }
    }, 3000);

    // Auto-hide after 8 more seconds
    setTimeout(() => {
      if (!dismissed && !hoverOpen) {
        tooltip.classList.remove("visible");
      }
    }, 11000);

    // Close button
    closeBtn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      dismissed = true;
      tooltip.classList.remove("visible");
    });

    // Show on hover
    button.addEventListener("mouseenter", () => {
      hoverOpen = true;
      tooltip.classList.add("visible");
    });

    // Hide on mouse leave (from entire wrapper)
    wrapper.addEventListener("mouseleave", () => {
      hoverOpen = false;
      if (dismissed) {
        tooltip.classList.remove("visible");
      }
    });
  }
</script>
