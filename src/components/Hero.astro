---
import laptop from "../assets/laptopNueva.png";
---

<section>
  <div class="container">
    <!-- textito -->
    <div class="hero-text">
      <h1>
        Protege tu futuro <br />
        con expertos en seguros
      </h1>
      <p>
        En Aguayo & Asociados tenemos el <strong>seguro ideal</strong> que necesitas
        para cuidar tu patrimonio, tu familia y tu tranquilidad.
      </p>
      <div class="buttons">
        <a href="#" class="btn-primary">Empezar</a>
        <a href="#" class="btn-secondary">¿Quiénes somos?</a>
      </div>
    </div>

    <!-- imagenes -->
    <div class="hero-images">
      <div class="mockup">
        <img src={laptop.src} class="laptop" alt="editor" />

        <video class="screen" autoplay loop muted playsinline>
          <source src="/VideoLaptop2.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 120px 0 100px 0;
    color: white;
    position: relative;
  }

  .container {
    max-width: 1350px;
    margin: auto;
    display: grid;
    grid-template-columns: 4fr 5fr;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* txt */
  .hero-text h1 {
    font-size: 70px;
    line-height: 1.1;
    font-weight: 700;
    margin-top: -6rem;
  }

  .hero-text p {
    font-size: 20px;
    opacity: 0.9;
    max-width: 600px;
    margin-bottom: 50px;
    line-height: 1.7;
  }

  /* btns*/
  .buttons {
    display: flex;
    gap: 16px;
  }

  .btn-primary {
    background: #1d2433;
    padding: 14px 26px;
    border-radius: 8px;
    color: white;
    text-decoration: none;
    font-weight: 600;
  }

  .btn-secondary {
    border: 1px solid rgba(255, 255, 255, 0.4);
    padding: 14px 26px;
    border-radius: 8px;
    color: white;
    text-decoration: none;
  }

  /* IMÁGENES */
  .hero-images {
    position: relative;
    margin-top: 3rem;
    padding-left: 5rem;
  }

  .mockup {
    position: relative;
    width: 135%;
    animation: slideUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes slideUp {
    0% {
      opacity: 0;
      transform: translateY(80px);
    }
    /* 40% { */
    /*   opacity: 0.4; */
    /* } */
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .laptop {
    width: 104.5%;
    display: block;
  }

  .screen {
    position: absolute;
    top: 6.2%;
    left: 2%;
    width: 100%;
    height: 91.5%;
    object-fit: cover;
    border: none;
    pointer-events: none;
  }

  .hero-text,
  .hero-images {
    position: relative;
    color: #fff;
  }
</style>
