        </ul>
      </div>

      <div class="about-us">
        <div class="title-footer">Contacto</div>
        <ul>
          <li><a href="tel:+526671234567">📞 (667) 123-4567</a></li>
          <li>
            <a href="mailto:contacto@segurosaguayo.com"
              >✉️ contacto@segurosaguayo.com</a
            >
          </li>
          <li>
            <a href="https://wa.me/5216671234567" target="_blank" rel="noopener"
              >💬 WhatsApp</a
            >
          </li>
          <li><a href="#">📍 Culiacán, Sinaloa, México</a></li>
        </ul>
      </div>
    </div>

    <div class="fourth-column">
      <div class="resources">
        <div class="title-footer">Aseguradoras</div>
        <ul>
          <li><a href="#">GNP Seguros</a></li>
          <li><a href="#">AXA Seguros</a></li>
          <li><a href="#">MetLife</a></li>
          <li><a href="#">MAPFRE</a></li>
          <li><a href="#">Quálitas</a></li>
        </ul>
      </div>

      <div class="resources">
        <div class="title-footer">Legal</div>
        <ul>
          <li><a href="#">Aviso de privacidad</a></li>
          <li><a href="#">Términos y condiciones</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>
        © 2026 Aguayo y Asociados · Agentes de seguros autorizados · Culiacán,
        Sinaloa
      </p>
      <div class="stellar-logo">
        <img src={logoWhite.src} alt="Aguayo y Asociados" />
      </div>
    </div>
  </div>
</section>

<style>
  .footer {
    background-color: #1a202c;
    color: #ffffff;
    padding: 80px 0 0 0;
    font-family: "Inter", sans-serif;
  }

  .footer .container {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 40px;
    max-width: 1350px;
    margin: 0 auto;
    padding: 0 20px 60px 20px;
  }

  /* Columnas */
  .first-column {
    flex: 1.5;
    min-width: 250px;
  }
  .second-column,
  .third-column,
  .fourth-column {
    flex: 1;
    min-width: 200px;
  }

  /* Logo */
  .logo-footer {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 50px;
  }

  .logo-icon {
    height: 35px;
  }

  .logo-text {
    height: 35px;
  }

  /* Made in / location text */
  .made-in p {
    color: #a0aec0;
    font-size: 14px;
    margin: 0 0 6px 0;
  }

  .made-in .tagline {
    color: #718096;
    font-size: 13px;
    font-style: italic;
    margin-bottom: 25px;
  }

  /* Social links */
  .social-links {
    display: flex;
    gap: 12px;
    margin-bottom: 30px;
  }

  .social-links a {
    background: #4a5568;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
    text-decoration: none;
  }

  .social-links a:hover {
    background: #718096;
  }

  .social-links svg {
    width: 20px;
    height: 20px;
    fill: #ffffff;
    display: block;
  }

  /* Trustpilot / years badge */
  .trustpilot p {
    font-size: 14px;
    font-weight: 600;
  }

  /* Listas y Títulos */
  .title-footer {
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    color: #ffffff;
  }

  .about-us,
  .resources {
    margin-bottom: 40px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  ul li {
    margin-bottom: 12px;
  }

  ul li a {
    color: #cbd5e0;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }

  ul li a:hover {
    color: #ffffff;
  }

  /* Footer bar */
  .footer-bottom {
    border-top: 1px solid #2d3748;
    padding: 30px 0;
    margin-top: 40px;
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0;
  }

  .footer-bottom p {
    color: #a0aec0;
    font-size: 13px;
    margin: 0;
  }

  .stellar-logo img {
    height: 30px;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .footer .container {
      flex-direction: column;
      text-align: left;
    }
    .footer-bottom .container {
      flex-direction: column;
      gap: 20px;
    }
  }
</style>
