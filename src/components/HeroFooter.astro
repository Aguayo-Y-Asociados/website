---
import phone from "../assets/logoPhone.png";
---

<div class="full-gray">
  <div class="box">
    <div class="box-container">
      <div class="box-icon">
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#0273e7"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
      </div>
      <div class="box-text">
        <h3>+1,000 familias</h3>
        <p>PROTEGIDAS CON NOSOTROS</p>
      </div>
    </div>

    <div class="box-container">
      <div class="box-icon">
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#0273e7"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon
            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
          ></polygon>
        </svg>
      </div>
      <div class="box-text">
        <h3>18+ años</h3>
        <p>DE EXPERIENCIA</p>
      </div>
    </div>

    <!-- <div class="box-container"> -->
    <!--   <div class="box-icon"> -->
    <!--     <svg -->
    <!--       width="28" -->
    <!--       height="28" -->
    <!--       viewBox="0 0 24 24" -->
    <!--       fill="none" -->
    <!--       stroke="#0273e7" -->
    <!--       stroke-width="1.8" -->
    <!--       stroke-linecap="round" -->
    <!--       stroke-linejoin="round" -->
    <!--     > -->
    <!--       <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path> -->
    <!--     </svg> -->
    <!--   </div> -->
    <!--   <div class="box-text"> -->
    <!--     <h3>5 aseguradoras</h3> -->
    <!--     <p>ALIADAS DE CONFIANZA</p> -->
    <!--   </div> -->
    <!-- </div> -->

    <div class="box-container">
      <div class="box-icon">
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#0273e7"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <div class="box-text">
        <h3>Asesoría gratuita</h3>
        <p>SIN COMPROMISO</p>
      </div>
    </div>

    <div class="hero-images">
      <img src={phone.src} class="phone" alt="mobile preview" />
    </div>
  </div>
</div>

<style>
  .full-gray {
    background: #f3f4f6;
  }

  .box {
    max-width: 1400px;
    margin: auto;
    display: flex;
    align-items: center;
    gap: 90px;
    height: 140px;
  }

  .box-container {
    text-align: left;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .box-icon {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    background: #e8f0fe;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .box-text {
    display: flex;
    flex-direction: column;
  }

  .box-container h3 {
    font-size: 18px;
    font-weight: 700;
    color: #1c2d43;
    margin: 0 0 4px 0;
  }

  .box-container p {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #6b7280;
    margin: 0;
  }

  .hero-images {
    position: relative;
  }

  .phone {
    position: absolute;
    width: 280px;
    bottom: -30px;
    left: -30px;
    z-index: 999;
    animation: slideLeft 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes slideLeft {
    0% {
      opacity: 0;
      transform: translateX(100px);
    }
    40% {
      opacity: 0.4;
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
