---
import phone from "../assets/phone.webp";
---

<div class="full-gray">
  <div class="box">
    <div class="box-container">
      <h3>400k+ websites</h3>
      <p>BUILT WITH KADENCE</p>
    </div>

    <div class="box-container">
      <h3>4.9 star</h3>
      <p>USER RATING</p>
    </div>

    <div class="box-container">
      <h3>#1 Rated for</h3>
      <p>WEB ACCESSIBILITY</p>
    </div>

    <div class="box-container">
      <h3>Free and Pro</h3>
      <p>PLANS AVAILABLE</p>
    </div>
    <div class="hero-images">
      <img src={phone.src} class="phone" alt="mobile preview" />
    </div>
  </div>
</div>

<style>
  .full-gray {
    background: #f3f4f6;
    padding: 23px 0;
  }

  .box {
    max-width: 1400px;
    margin: auto;

    gap: 40px;
  }

  .box-container {
    text-align: left;
  }

  .box-container h3 {
    font-size: 18px;
    font-weight: 700;
    color: #1c2d43;
    margin-bottom: 12px;
  }

  .box-container p {
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #1c2d43;
  }

  /* IMÁGENES */
  .hero-images {
    position: relative;
  }

  .phone {
    position: absolute;
    width: 290px;
    bottom: 30px;
    left: 110px;
    z-index: 999;
  }
</style>
