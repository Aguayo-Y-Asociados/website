---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Whatsapp from "../components/Whatsapp.astro";
import quienesSomos from "../assets/quienes-somos.png";
---

<Layout>

  <section class="header">
    <!-- <span class="header-badge">Nuestra Historia</span> -->
    <h1 class="title">Nosotros</h1>
    <p class="header-subtitle">
      Conoce al equipo que protege lo que más importa para ti y tu familia.
    </p>
  </section>

</Layout>

<!-- ===== QUIÉNES SOMOS ===== -->
<section class="about-section">
  <div class="about-wrapper">
    <div class="about-header">
      <span class="about-badge">Aguayo & Asociados</span>
      <h2>¿Quiénes somos?</h2>
      <p>
        En Aguayo & Asociados, somos expertos en seguros, protección financiera y crecimiento patrimonial. Nos especializamos en brindar soluciones que resguarden lo más importante para nuestros clientes: su bienestar, el de su familia y su futuro financiero.
      </p>
    </div>

    <div class="about-card">
      <div class="about-grid">
        <div class="about-image">
          <img
            src={quienesSomos.src}
            alt="Equipo Aguayo y Asociados"
          />
        </div>

        <div class="about-text">
          <div class="highlight-box">
            <p>
              Con más de <strong>17 años de experiencia</strong>, hemos logrado posicionarnos dentro del <strong>Top 10 a nivel nacional en GNP Seguros</strong>, respaldando a cientos de personas con planes de protección, inversión y retiro diseñados a la medida de sus necesidades en toda la república mexicana.
            </p>
          </div>

          <div class="stats-row">
            <div class="stat-item">
              <div class="stat-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0273e7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
              </div>
              <div>
                <h4>+1,000 familias</h4>
                <p>protegidas con nosotros</p>
              </div>
            </div>

            <div class="stat-item">
              <div class="stat-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0273e7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              </div>
              <div>
                <h4>Top 10 Nacional</h4>
                <p>en GNP Seguros</p>
              </div>
            </div>

            <div class="stat-item">
              <div class="stat-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0273e7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              </div>
              <div>
                <h4>17+ años</h4>
                <p>de experiencia</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

