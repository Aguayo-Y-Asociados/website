---
import BaseLayout from "../layouts/BaseLayout.astro";
import Drafts from "../components/Drafts.astro";
import Questions from "../components/Questions.astro";
// import Help from "../components/Help.astro";
import Footer from "../components/Footer.astro";
import Carousel from "../components/Carousel.astro";
import Whatsapp from "../components/Whatsapp.astro";
---

<BaseLayout />

<section class="features">
  <div class="features-header">
    <span class="features-badge">Nuestra Historia</span>
    <h2>¿Quiénes Somos?</h2>
    <p>
      Somos especialistas en seguros con sede en Culiacán, Sinaloa. Contamos con
      18 años de experiencia ayudando a personas y familias a proteger lo que
      más importa. Nuestro compromiso es ofrecer soluciones claras,
      personalizadas y confiables para cuidar tu vida, tu salud, tu patrimonio y
      tu futuro.
    </p>
  </div>

  <div class="features-card">
    <div class="features-grid">
      <div class="features-images">
        <img
          src="/src/assets/quienes-somos.png"
          class="feature-img"
          alt="Equipo Aguayo y Asociados"
        />
      </div>

      <div class="features-text">
        <div class="feature">
          <div class="feature-icon">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#0273e7"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <div class="feature-content">
            <h3>Claudio Aguayo</h3>
            <span class="feature-role">Director general</span>
            <p>
              Con más de 18 años liderando la empresa, Claudio Aguayo es el
              pilar estratégico que guía cada decisión con visión, experiencia y
              un profundo compromiso con cada cliente.
            </p>
          </div>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#0273e7"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <div class="feature-content">
            <h3>Enrique Aguayo</h3>
            <span class="feature-role">Asesor de seguros</span>
            <p>
              Especialista en seguros de vida y gastos médicos. Enrique Aguayo
              se dedica a encontrar la póliza perfecta que se adapte a las
              necesidades únicas de cada familia.
            </p>
          </div>
        </div>

        <div class="feature">
          <div class="feature-icon">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#0273e7"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <div class="feature-content">
            <h3>Diego Aguayo</h3>
            <span class="feature-role">Asesor de Seguros</span>
            <p>
              Experto en seguros patrimoniales y empresariales. Diego ayuda a
              empresas y particulares a proteger sus bienes con soluciones
              integrales y personalizadas.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section>
  <Drafts />
</section>

